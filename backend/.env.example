# Application
APP_NAME=SmartLoan AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Security
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./smartloan.db
# DATABASE_URL=postgresql://smartloan:password@localhost:5432/smartloan_db

# CORS
FRONTEND_URL=http://localhost:5173

# Email (optional — stub in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
